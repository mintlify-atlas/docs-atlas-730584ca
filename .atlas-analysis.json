  "keyFeatures": [
    "Wavefront Threading execution model for deterministic concurrency",
    "Wavefront Consistency memory model aligned with synchronous circuits",
    "Composable abstractions with functions, lambdas, and strong typing",
    "Rich standard library with data structures and IP blocks",
    "RISC-V processor cores with multi-hart support",
    "Floating-point arithmetic libraries",
    "Compiles to efficient SystemVerilog RTL",
    "Competitive performance with hand-written HDL"
  ],
  "publicApiSurface": [
    "kanagawa compiler executable",
    "Standard library modules: base, data, numeric, sync, control, processor",
    "RISC_V class template for processor cores",
    "Data structures: Array, Vector, FIFO, Buffer, HashTable, Memory",
    "Numeric types: fixed-point, float32, float64, complex",
    "Synchronization primitives: atomic, lock",
    "Control flow: Loop, FSM, async rendezvous",
    "Device IP: Intel and Xilinx FPGA primitives",
    "Type system: integers (arbitrary width), structs, unions, enums, classes"
  ]
